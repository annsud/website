---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, url } from '@/lib/site';
---

<BaseLayout title="About">
  <section class="mx-auto max-w-3xl px-5 pt-12 pb-4 sm:px-8">
    <h1 class="font-display text-4xl font-semibold tracking-tight">About</h1>

    <div class="prose-editorial mt-6">
      <p>
        I am a Professor at the Department of Economics at the University of
        Warwick and a Senior Fellow at the Energy Policy Institute at the
        University of Chicago (EPIC). Before joining the University of Warwick, I
        was the South Asia Director of EPIC and taught at the Harris School of
        Public Policy at the University of Chicago.
      </p>
      <p>
        I received my PhD in Management Science and Engineering from Stanford
        University and hold undergraduate and master's degrees in mechanical
        engineering from the Indian Institute of Technology (Delhi) and Stanford
        University respectively.
      </p>
      <p>
        My research spans several aspects of energy and environment policy
        including the design of environmental regulation, reducing air pollution,
        climate change, energy efficiency, electricity access, and renewable
        energy policy.
      </p>
      <p>
        I also spend an inordinate amount of time watching murder mysteries on
        TV — probably enough to merit inclusion here.
      </p>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={url('/cv')}
        class="rounded-md border border-[var(--color-line)] px-4 py-2 text-sm font-medium hover:border-[var(--color-accent)]"
        >Curriculum vitae</a
      >
      <a
        href={`mailto:${SITE.email}`}
        class="rounded-md border border-[var(--color-line)] px-4 py-2 text-sm font-medium hover:border-[var(--color-accent)]"
        >Email</a
      >
      <a
        href={SITE.links.scholar}
        target="_blank"
        rel="noopener"
        class="rounded-md border border-[var(--color-line)] px-4 py-2 text-sm font-medium hover:border-[var(--color-accent)]"
        >Google Scholar</a
      >
    </div>
  </section>
</BaseLayout>
