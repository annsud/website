---
import { getCollection, render } from 'astro:content';
import PaperLayout from '@/layouts/PaperLayout.astro';

// Only tier-2 "dossier" papers get a dedicated page. Every other paper shows
// its abstract + media inline (expandable) on the research index.
export async function getStaticPaths() {
  const papers = await getCollection('papers');
  return papers
    .filter((p) => p.data.tier === 2)
    .map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<PaperLayout entry={entry}>
  <Content />
</PaperLayout>
