---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PaperCard from '@/components/PaperCard.astro';
import { SITE, url } from '@/lib/site';

// "New research" = the most recent working papers and journal articles,
// curated via the `featured` flag in each paper's frontmatter.
const featured = (await getCollection('papers'))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);
---

<BaseLayout>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-5 pt-16 pb-12 sm:px-8">
    <div class="grid items-start gap-10 sm:grid-cols-[1.5fr_auto]">
      <div class="rise">
        {
          SITE.role && (
            <p class="mb-3 text-sm font-semibold tracking-[0.12em] text-[var(--color-accent)] uppercase">
              {SITE.role}
            </p>
          )
        }
        <h1
          class="font-display text-4xl leading-[1.05] font-semibold tracking-tight sm:text-6xl"
        >
          {SITE.name}
        </h1>
        <p class="mt-5 max-w-xl text-lg text-[#334155]">
          {SITE.description}
        </p>
        <p class="mt-4 text-sm text-[var(--color-muted)]">{SITE.affiliation}</p>
      </div>

      <div class="rise justify-self-start sm:justify-self-end">
        <img
          src={url('/Headshot.jpg')}
          alt={SITE.name}
          class="aspect-[4/5] w-44 rounded-2xl border border-[var(--color-line)] object-cover object-[20%_center] shadow-sm"
        />
      </div>
    </div>
  </section>

  <!-- New research (left-aligned with the hero) -->
  {
    featured.length > 0 && (
      <section class="mx-auto mt-6 max-w-5xl px-5 sm:px-8">
        <h2 class="font-display text-2xl font-semibold">New Research</h2>
        <p class="mt-2 text-[var(--color-muted)]">
          The latest working papers and journal articles.
        </p>
        <div class="mt-2 max-w-3xl">
          {featured.map((entry) => (
            <PaperCard entry={entry} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
