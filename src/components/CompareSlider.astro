---
import { url } from '@/lib/site';
// Before/after image comparison slider. Pure CSS + a few lines of JS, no deps.
// Great for "with vs without intervention" results or map overlays.
interface Props {
  before: string;
  after: string;
  beforeLabel?: string;
  afterLabel?: string;
  alt?: string;
  caption?: string;
}
const {
  before: beforeRaw,
  after: afterRaw,
  beforeLabel = 'Before',
  afterLabel = 'After',
  alt = '',
  caption,
} = Astro.props;
const before = url(beforeRaw);
const after = url(afterRaw);
const id = `cmp-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class="my-8">
  <div
    id={id}
    class="compare relative aspect-[16/10] w-full overflow-hidden rounded-lg border border-[var(--color-line)] select-none"
  >
    <img src={after} alt={alt} class="absolute inset-0 h-full w-full object-cover" />
    <span
      class="absolute right-3 bottom-3 rounded bg-black/60 px-2 py-0.5 text-xs text-white"
      >{afterLabel}</span
    >
    <div class="clip absolute inset-0 overflow-hidden" style="width:50%">
      <img
        src={before}
        alt={alt}
        class="absolute inset-0 h-full w-full max-w-none object-cover"
      />
      <span
        class="absolute bottom-3 left-3 rounded bg-black/60 px-2 py-0.5 text-xs text-white"
        >{beforeLabel}</span
      >
    </div>
    <div
      class="handle absolute top-0 bottom-0 w-0.5 -translate-x-1/2 bg-white shadow"
      style="left:50%"
    >
      <div
        class="absolute top-1/2 left-1/2 grid h-9 w-9 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full bg-white text-[var(--color-ink)] shadow"
      >
        ⇆
      </div>
    </div>
    <input
      type="range"
      min="0"
      max="100"
      value="50"
      aria-label="Comparison slider"
      class="range absolute inset-0 h-full w-full cursor-ew-resize opacity-0"
    />
  </div>
  {
    caption && (
      <figcaption class="mt-2 text-sm text-[var(--color-muted)]">
        {caption}
      </figcaption>
    )
  }
</figure>

<script define:vars={{ id }}>
  const root = document.getElementById(id);
  if (root) {
    const clip = root.querySelector('.clip');
    const handle = root.querySelector('.handle');
    const range = root.querySelector('.range');
    range.addEventListener('input', () => {
      const v = range.value + '%';
      clip.style.width = v;
      handle.style.left = v;
    });
  }
</script>
