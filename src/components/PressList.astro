---
interface Item {
  outlet: string;
  title: string;
  url: string;
  date?: string;
}
interface Props {
  items: Item[];
  heading?: string;
}
const { items, heading = 'In the press' } = Astro.props;
---

{
  items.length > 0 && (
    <section class="my-8">
      <h3 class="mb-3 text-xs font-semibold tracking-[0.08em] text-[var(--color-muted)] uppercase">
        {heading}
      </h3>
      <ul class="divide-y divide-[var(--color-line)] border-y border-[var(--color-line)]">
        {items.map((it) => (
          <li>
            <a
              href={it.url}
              target="_blank"
              rel="noopener"
              class="group flex items-baseline justify-between gap-4 py-2.5"
            >
              <span class="flex items-baseline gap-3">
                <span class="font-medium text-[var(--color-accent)]">
                  {it.outlet}
                </span>
                <span class="text-[var(--color-ink)] group-hover:underline">
                  {it.title}
                </span>
              </span>
              {it.date && (
                <span class="shrink-0 text-sm text-[var(--color-muted)]">
                  {it.date}
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
