---
import type { CollectionEntry } from 'astro:content';
import { url } from '@/lib/site';
import { authorParts, statusLabel } from '@/lib/format';
import PaperLinks from './PaperLinks.astro';
import PressList from './PressList.astro';
import Awards from './Awards.astro';
import FollowUps from './FollowUps.astro';
import Cite from './Cite.astro';

interface Props {
  entry: CollectionEntry<'papers'>;
}
const { entry } = Astro.props;
const p = entry.data;
const href = url(`/papers/${entry.id}`);
const authors = authorParts(p.authors);
const hasProjectPage = p.tier === 2; // flagship studies get a full project page
const hasExtra = Boolean(
  p.abstract || p.press.length || p.awards.length || p.followUps.length
);
---

<article class="border-b border-[var(--color-line)] py-8 first:pt-0">
  <div class="min-w-0">
    <div
      class="mb-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-[var(--color-muted)]"
    >
      <span class="font-medium">{statusLabel(p.status)}</span>
      <span>{p.year}</span>
      {
        p.venue && (
          <span class="text-sm font-semibold text-[var(--color-accent)]">
            {p.venue}
          </span>
        )
      }
      {
        hasProjectPage && (
          <span class="rounded-full bg-[var(--color-accent-soft)] px-2 py-0.5 font-medium text-[var(--color-accent)]">
            Project page
          </span>
        )
      }
    </div>

    <h3 class="font-display text-xl leading-snug font-semibold">
      {
        hasProjectPage ? (
          <a href={href} class="hover:text-[var(--color-accent)]">
            {p.title}
          </a>
        ) : (
          p.title
        )
      }
    </h3>

    <p class="mt-1 text-sm text-[var(--color-muted)]">
      {
        authors.map((a, i) => (
          <>
            {i > 0 && ', '}
            <span class:list={[a.me && 'font-semibold text-[var(--color-ink)]']}>
              {a.name}
            </span>
          </>
        ))
      }
    </p>

    <p class="mt-3 max-w-prose text-[0.95rem] text-[#334155]">{p.summary}</p>

    <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-2">
      <PaperLinks links={p.links} size="sm" />
      <Cite data={p} size="sm" />
      {
        hasProjectPage && (
          <a
            href={href}
            class="text-sm font-medium text-[var(--color-accent)] hover:underline"
          >
            Open project page →
          </a>
        )
      }
    </div>

    {/* Lightweight inline reveal: abstract + media, no page load. */}
    {
      hasExtra && (
        <details class="mt-4 rounded-lg border border-[var(--color-line)] bg-white px-4 [&[open]>summary>.chev]:rotate-180">
          <summary class="flex cursor-pointer list-none items-center justify-between py-3 text-sm font-medium text-[var(--color-muted)] hover:text-[var(--color-accent)]">
            <span>Abstract &amp; media</span>
            <span class="chev text-xs transition-transform">▾</span>
          </summary>
          <div class="pb-1">
            {p.abstract && (
              <p class="prose-editorial border-l-2 border-[var(--color-accent)] pl-4 text-[var(--color-muted)] italic">
                {p.abstract}
              </p>
            )}
            <Awards items={p.awards} />
            <FollowUps items={p.followUps} heading="Related projects & impact" />
            <PressList items={p.press} heading="Media & press" />
          </div>
        </details>
      )
    }
  </div>
</article>
