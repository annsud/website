---
import type { CollectionEntry } from 'astro:content';
import { url } from '@/lib/site';
import { byline } from '@/lib/format';
import PaperLinks from './PaperLinks.astro';
import PressList from './PressList.astro';
import FollowUps from './FollowUps.astro';
import Cite from './Cite.astro';

interface Props {
  entry: CollectionEntry<'papers'>;
}
const { entry } = Astro.props;
const p = entry.data;
const href = url(`/papers/${entry.id}`);
const { self, others } = byline(p.authors);
const hasProjectPage = p.tier === 2; // (currently none — reserved)
const published = p.status === 'published';
const hasAbstract = Boolean(p.abstract || p.figure);
const hasMedia = Boolean(p.press.length || p.followUps.length);
const absId = `abs-${entry.id}`;
const medId = `med-${entry.id}`;
---

<article
  class="grid grid-cols-[1fr_auto] gap-x-5 border-b border-[var(--color-line)] py-7 first:pt-0"
>
  <div class="min-w-0">
    <h3 class="font-display text-xl leading-snug font-semibold">
      {
        hasProjectPage ? (
          <a href={href} class="hover:text-[var(--color-accent)]">
            {p.title}
          </a>
        ) : (
          p.title
        )
      }
    </h3>

    {/* Journal below the title: accent for published, muted for working papers. */}
    {
      p.venue &&
        (published ? (
          <p class="mt-1 text-sm font-semibold text-[var(--color-accent)]">
            {p.venue}
          </p>
        ) : (
          <p class="mt-1 text-sm font-medium text-[var(--color-muted)] italic">
            {p.venue}
          </p>
        ))
    }

    {/* Anant-first byline (author lists are alphabetical). */}
    <p class="mt-1 text-sm text-[var(--color-muted)]">
      <span class="font-semibold text-[var(--color-ink)]">{self}</span>
      {others.length > 0 && <> (with {others.join(', ')})</>}
    </p>

    {/* Awards: rare and important, so shown without a click. */}
    {
      p.awards.length > 0 && (
        <div class="mt-2.5 flex flex-wrap gap-2">
          {p.awards.map((a) => {
            const Tag = a.url ? 'a' : 'span';
            const meta = [a.org, a.year].filter(Boolean).join(' · ');
            return (
              <Tag
                href={a.url}
                target={a.url ? '_blank' : undefined}
                rel={a.url ? 'noopener' : undefined}
                class:list={[
                  'inline-flex items-center gap-1.5 rounded-full border border-amber-300 bg-amber-50 px-3 py-1 text-xs font-medium text-amber-800',
                  a.url && 'transition-colors hover:border-amber-500',
                ]}
              >
                <span aria-hidden="true">★</span>
                <span>
                  {a.title}
                  {meta && ` · ${meta}`}
                </span>
              </Tag>
            );
          })}
        </div>
      )
    }

    <p class="mt-3 max-w-prose text-[0.95rem] text-[#242424]">{p.summary}</p>

    <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-2">
      <PaperLinks links={p.links} size="sm" />
      <Cite data={p} size="sm" />
      {
        hasProjectPage && (
          <a
            href={href}
            class="text-sm font-medium text-[var(--color-accent)] hover:underline"
          >
            Open project page →
          </a>
        )
      }
    </div>

    {/* Two separate reveals: Abstract (with a key figure) and Media. */}
    {
      (hasAbstract || hasMedia) && (
        <div class="mt-4">
          <div class="flex flex-wrap gap-2">
            {hasAbstract && (
              <button
                type="button"
                class="reveal-btn rounded-md border border-[var(--color-line)] bg-white px-3 py-1 text-xs font-medium text-[var(--color-ink)] transition-colors hover:border-[var(--color-accent)]"
                data-target={absId}
                aria-expanded="false"
              >
                Abstract
              </button>
            )}
            {hasMedia && (
              <button
                type="button"
                class="reveal-btn rounded-md border border-[var(--color-line)] bg-white px-3 py-1 text-xs font-medium text-[var(--color-ink)] transition-colors hover:border-[var(--color-accent)]"
                data-target={medId}
                aria-expanded="false"
              >
                Media
              </button>
            )}
          </div>

          {hasAbstract && (
            <div id={absId} class="reveal-panel mt-3 hidden">
              {p.abstract && (
                <p class="prose-editorial border-l-2 border-[var(--color-accent)] pl-4 text-[var(--color-muted)] italic">
                  {p.abstract}
                </p>
              )}
              {p.figure && (
                <figure class="mt-4">
                  <img
                    src={url(p.figure)}
                    alt={p.figureAlt ?? `Key figure from ${p.title}`}
                    loading="lazy"
                    class="w-full rounded-lg border border-[var(--color-line)] bg-white"
                  />
                  {p.figureCaption && (
                    <figcaption class="mt-1.5 text-xs text-[var(--color-muted)]">
                      {p.figureCaption}
                    </figcaption>
                  )}
                </figure>
              )}
            </div>
          )}

          {hasMedia && (
            <div id={medId} class="reveal-panel mt-3 hidden">
              <FollowUps items={p.followUps} heading="Related projects & impact" />
              <PressList items={p.press} heading="Media & press" />
            </div>
          )}
        </div>
      )
    }
  </div>

  <div class="pt-1 text-right">
    <span
      class="font-display text-lg font-semibold tabular-nums text-[var(--color-ink)]"
    >
      {p.year}
    </span>
  </div>
</article>

<script>
  // Toggle an Abstract / Media panel independently (delegated, bundled once).
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.reveal-btn');
    if (!btn) return;
    const id = btn.dataset.target;
    const panel = id ? document.getElementById(id) : null;
    if (!panel) return;
    const open = panel.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
